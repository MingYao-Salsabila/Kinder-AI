# --- App ---
APP_NAME=KinderAi
APP_ENV=development
DEFAULT_MODE=landing

# --- Gemini ---
# Leave GEMINI_USE_STUB=true (the default) to run fully offline with
# deterministic placeholder responses -- no API key needed, and no network
# calls are made. This is the recommended setting for demos and CI.
#
# To call the real Gemini API:
#   1. Get a key from https://aistudio.google.com/app/apikey
#   2. Set GEMINI_API_KEY below
#   3. Set GEMINI_USE_STUB=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_USE_STUB=true
GEMINI_MAX_OUTPUT_TOKENS=1024

# --- Local storage ---
# Relative paths are resolved against the project root, so the app works
# the same regardless of the current working directory it's launched from.
SQLITE_PATH=app/db/kinderai.sqlite3
VECTOR_INDEX_PATH=app/data/vector_index
KNOWLEDGE_BASE_PATH=app/data/knowledge_base
