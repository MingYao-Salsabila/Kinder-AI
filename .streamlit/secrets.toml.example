
# Copy this file to `.streamlit/secrets.toml` for local development, or paste
# its contents into the "Secrets" section of your Streamlit Community Cloud
# app settings (Settings -> Secrets).
#
# Streamlit exposes every key defined here as an environment variable, so
# KinderAi's config (app/config.py) picks it up the same way it reads `.env`.
#
# NEVER commit `.streamlit/secrets.toml` -- it's listed in .gitignore.

GEMINI_API_KEY = "your-real-gemini-api-key"
GEMINI_USE_STUB = "false"

